{
  "name": "dusty-mac",
  "version": "1.0.0",
  "description": "Beautiful TUI app to clean junk from your Mac — like CleanMyMac in your terminal",
  "keywords": [
    "mac",
    "cleaner",
    "cleanup",
    "tui",
    "cli",
    "macos",
    "disk-space"
  ],
  "license": "MIT",
  "author": "",
  "bin": {
    "dusty-mac": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "fast-glob": "^3.3.2",
    "filesize": "^10.1.6",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
